generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique // Clerk User ID
  username        String   @unique
  email           String   @unique
  imageUrl        String?  @db.Text
  bio             String?  @db.Text
  githubUsername  String?
  reputation      Int      @default(0)
  streakCount     Int      @default(0)
  lastActivityDate DateTime?
  
  posts           Post[]
  comments        Comment[]
  likes           Like[]
  snippets        Snippet[]
  projects        Project[]
  codeReviews     CodeReview[]
  reviewComments  ReviewComment[]
  
  following       Follow[] @relation("Following")
  followers       Follow[] @relation("Followers")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Feedback {
  id        String   @id @default(cuid())
  email     String
  name      String?
  message   String   @db.Text
  status    String   @default("pending") // pending, read, resolved

  createdAt DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  tags      String[] @default([])
  status    String   @default("broadcast") // draft, broadcast
  published Boolean  @default(true)
  authorId  String
  author    Profile  @relation(fields: [authorId], references: [userId], onDelete: Cascade)
  
  likes     Like[]
  comments  Comment[]
  views     View[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  user        Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  repoName    String
  description String?  @db.Text
  stars       Int      @default(0)
  forks       Int      @default(0)
  language    String?
  repoUrl     String
  
  reviews     CodeReview[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model CodeReview {
  id          String   @id @default(cuid())
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  authorId    String
  author      Profile  @relation(fields: [authorId], references: [userId], onDelete: Cascade)
  title       String
  codeSnippet String   @db.Text
  language    String
  
  comments    ReviewComment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([authorId])
}

model ReviewComment {
  id          String   @id @default(cuid())
  reviewId    String
  review      CodeReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  authorId    String
  author      Profile    @relation(fields: [authorId], references: [userId], onDelete: Cascade)
  content     String     @db.Text
  lineNumber  Int
  upvotes     Int        @default(0)
  isBest      Boolean    @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([reviewId])
  @@index([authorId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    Profile  @relation(fields: [authorId], references: [userId], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([authorId])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    Profile  @relation("Followers", fields: [followerId], references: [userId], onDelete: Cascade)
  followingId String
  following   Profile  @relation("Following", fields: [followingId], references: [userId], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Snippet {
  id        String   @id @default(cuid())
  title     String
  code      String   @db.Text
  language  String
  authorId  String
  author    Profile  @relation(fields: [authorId], references: [userId], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
}

model View {
  id        String   @id @default(cuid())
  postId    String?
  profileId String?
  viewerId  String? // Session-based or unauthenticated ID
  
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([postId])
}
